// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Country {
  TR
  DE
}

enum Role {
  USER
  ADMIN
}

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String
  name         String
  role         Role        @default(USER)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  profile      Profile?
  matchesAsA   Match[]     @relation("MatchA")
  matchesAsB   Match[]     @relation("MatchB")
  rounds       MatchRound[]
  groupMemberships MatchGroupMember[]
  resetTokens  PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Profile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  avatarUrl           String   @default("")
  instagramUrl        String   @default("")
  linkedinUrl         String   @default("")
  xUrl                String   @default("")
  publicTags          String[] @default([])
  answersEditable     Boolean  @default(true)
  includedInMatching  Boolean  @default(true)
  country             Country
  openness            Int
  conscientiousness   Int
  extraversion        Int
  agreeableness       Int
  neuroticism         Int
  interests           String
  bio                 String   @default("")
  travelAfterProgram  Boolean  @default(false)
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MatchRound {
  id          String       @id @default(cuid())
  createdAt   DateTime     @default(now())
  createdById String
  published   Boolean      @default(false)
  publishedAt DateTime?
  createdBy   User         @relation(fields: [createdById], references: [id])
  matches     Match[]
  groups      MatchGroup[]
}

model MatchGroup {
  id      String             @id @default(cuid())
  roundId String
  score   Float
  reason  String?
  round   MatchRound         @relation(fields: [roundId], references: [id], onDelete: Cascade)
  members MatchGroupMember[]
}

model MatchGroupMember {
  id      String     @id @default(cuid())
  groupId String
  userId  String
  group   MatchGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User       @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
}

model Match {
  id        String     @id @default(cuid())
  roundId   String
  personAId String
  personBId String
  score     Float
  reason    String?
  round     MatchRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  personA   User       @relation("MatchA", fields: [personAId], references: [id])
  personB   User       @relation("MatchB", fields: [personBId], references: [id])

  @@unique([roundId, personAId, personBId])
}
